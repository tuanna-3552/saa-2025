{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/session-start.sh\"",
            "async": false
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/session-state.cjs\"",
            "async": false
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/telemetry.cjs\"",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/telemetry.cjs\"",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/telemetry.cjs\"",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/session-state.cjs\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/safety-guard.cjs\"",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/iron-laws-guard.cjs\"",
            "async": true
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-$PWD}/hooks/telemetry.cjs\"",
            "async": true
          }
        ]
      }
    ]
  }
}
