{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "node \"$PWD/.claude/statusline.cjs\"",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/session-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/subagent-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/team-context-inject.cjs\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/takumi-after-plan-reminder.cjs\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/session-state.cjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/dev-rules-reminder.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/descriptive-name.cjs\""
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/safety-guard.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/scout-block.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/privacy-block.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/skill-dedup.cjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskCreate|TaskUpdate|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/session-state.cjs\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/iron-laws-guard.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/post-edit-simplify-reminder.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/plan-format-kanban.cjs\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/usage-context-awareness.cjs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/task-completed-handler.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PWD/.claude/hooks/teammate-idle-handler.cjs\""
          }
        ]
      }
    ]
  }
}