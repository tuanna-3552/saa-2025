{
  "name": "@saa/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('front-end/admin',{recursive:true});fs.cpSync('.next','front-end/admin/.next',{recursive:true});\"",
    "start": "next start --port 3001",
    "test": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "wrangler pages dev",
    "pages:deploy": "wrangler pages deploy"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@saa/shared-ui": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^0.475.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@playwright/test": "^1.60.0",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "16",
    "@testing-library/user-event": "^14",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-next-on-pages": "^1.13.12",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29",
    "jest-environment-jsdom": "29",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^3.114.4"
  }
}
