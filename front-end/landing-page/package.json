{
  "name": "@saa/landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "postbuild": "node -e \"const fs = require('fs'); fs.mkdirSync('front-end/landing-page', { recursive: true }); fs.cpSync('.next', 'front-end/landing-page/.next', { recursive: true });\"",
    "start": "next start --port 3000",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "wrangler pages dev",
    "pages:deploy": "wrangler pages deploy"
  },
  "dependencies": {
    "@saa/shared-ui": "workspace:*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "16",
    "@testing-library/user-event": "^14",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-next-on-pages": "^1.13.12",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29",
    "jest-environment-jsdom": "29",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^3.114.4"
  }
}
