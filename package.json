{
  "name": "saa-2025",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "build": "dotenv -e .env -- turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "dotenv -e .env -- turbo test",
    "test:e2e": "dotenv -e .env -- turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.0.0",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
